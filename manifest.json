{
  "id": "taskbar-lyric",
  "name": "任务栏歌词",
  "version": "1.4.1",
  "description": "在任务栏上方显示当前歌词和专辑封面的透明浮窗，自动检测任务栏位置并贴靠。",
  "author": "yaoyaoprincess",
  "icon": "icon.svg",
  "main": "index.js",
  "capabilities": {
    "localFiles": true
  },
  "requires": {
    "echoMusicVersion": ">=2.2.7-beta.1"
  },
  "contributes": {
    "windows": [
      {
        "id": "taskbar-lyric",
        "type": "floating",
        "title": "任务栏歌词",
        "main": "taskbar-lyric-window.js",
        "style": "taskbar-lyric-window.css",
        "defaultWidth": 400,
        "defaultHeight": 40,
        "minWidth": 200,
        "minHeight": 24,
        "maxWidth": 600,
        "maxHeight": 80,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "allowOutsideWorkArea": true,
        "resizable": true,
        "movable": true,
        "acceptFirstMouse": true
      }
    ]
  }
}
